+            owners[i] = o;
+            vm.deal(o, 100_000 ether);
+            _buyBox(o, 1 ether);
+        }
+        _injectLootboxRngWord(index, BOX_FIXED_WORD);
+
+        uint256 preStake = coinflip.coinflipAmount(cranker);
+        vm.prank(cranker);
