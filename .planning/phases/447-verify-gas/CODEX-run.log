   641	    ///      currency. `customTicket` is the matched foil line, so the spin plays the
   642	    ///      exact ticket that won (a non-zero value bypasses seed-derived generation).
   643	    function _foilSpin(
   644	        bytes4 selector,
   645	        address player,
   646	        uint256 stake,
   647	        uint16 activityScore,
   648	        uint256 seed,
   649	        uint32 customTicket
   650	    ) private {
   651	        (bool ok, ) = ContractAddresses.GAME_DEGENERETTE_MODULE.delegatecall(
   652	            abi.encodeWithSelector(
   653	                selector,
   654	                player,
   655	                stake,
   656	                activityScore,
   657	                seed,
   658	                customTicket
   659	            )
   660	        );
   661	        if (!ok) revert E();
   662	    }
   663	
   664	    // =========================================================================
   665	    // Queue drain (relocated here from the mint module so the near-full mint
   666	    // module keeps only the normal-ticket path under the EIP-170 limit)
   667	    // =========================================================================
   668	
   669	    /// @notice Drain the per-buy-day foil buckets on the leftover write budget.
   670	    /// @dev Delegatecall-only entry, invoked by the mint module's processTicketBatch
   671	    ///      once the normal queue is drained (and only when _foilDrainPending). Runs in
   672	    ///      the Game's storage context, so it reads/writes the same
   673	    ///      foilBuyers/foilDrainDay/foilCursor/foilRecord and the traitBurnTicket
   674	    ///      buckets the jackpot samples.
   675	    /// @param room The leftover write budget for this batch.
   676	    /// @return done True iff the foil drain has caught up (no sealed bucket remains).
   677	    function processFoilDrain(uint32 room) external returns (bool done) {
   678	        if (address(this) != ContractAddresses.GAME) revert E();
   679	        return _processFoilDrain(room);
   680	    }
   681	
   682	    /// @dev Walk the per-buy-day buckets forward from the low-water mark (foilDrainDay)
   683	    ///      up to the high-water mark (foilLastResolveDay), draining each whose daily
   684	    ///      word has sealed. Each buyer resolves a fixed FOIL_PACK_ENTRIES (16) boosted
   685	    ///      entries — four tickets x four quadrants — derived from rngWordByDay[bucket]
   686	    ///      + the buyer's frozen multBps, filed into the jackpot trait buckets (no
   687	    ///      stamp; the claim re-derives the same lines). foilCursor makes a
   688	    ///      budget-short deferral resumable; a whole buyer defers (never a partial pack)
   689	    ///      when the leftover budget can't cover the fixed 35-unit charge. A bucket
   690	    ///      whose word is not yet sealed (a future day) stops the walk — it does not
   691	    ///      gate the current jackpot.
   692	    function _processFoilDrain(uint32 room) private returns (bool done) {
   693	        uint24 dd = foilDrainDay;
   694	        uint24 last = foilLastResolveDay;
   695	        uint256 cursor = foilCursor;
   696	
   697	        // Trait-batch scratch shared across every buyer this call (re-zeroed per buyer
   698	        // inside _resolveFoilBuyer), so memory does not grow per queue entry.
   699	        uint32[256] memory counts;
   700	        uint8[256] memory touchedTraits;
   701	
   702	        while (dd <= last) {
   703	            uint256 entropy = rngWordByDay[dd];
   704	            if (entropy == 0) break; // future-dated bucket: its word has not sealed yet
   705	
   706	            uint256[] storage bucket = foilBuyers[dd];
   707	            uint256 total = bucket.length;
   708	            while (cursor < total) {
   709	                // A foil pack resolves a fixed FOIL_PACK_ENTRIES (16) boosted entries at
   710	                // a fixed cost of 16*2 trait-writes + baseOv(2) + 1 = 35 budget units.
   711	                // Defer the whole buyer when the leftover budget can't cover a full
   712	                // pack; it resumes next tx (no partial-within-buyer, no brick). The
   713	                // guard MUST equal the charge below: a smaller guard lets `room` just
   714	                // above it underflow the unchecked charge and drain everything in one tx.
   715	                if (room < (FOIL_PACK_ENTRIES * 2) + 3) {
   716	                    foilDrainDay = dd;
   717	                    foilCursor = uint32(cursor);
   718	                    return false;
   719	                }
   720	                _resolveFoilBuyer(bucket[cursor], entropy, counts, touchedTraits);
   721	                unchecked {
   722	                    room -= (FOIL_PACK_ENTRIES * 2) + 3; // 16*2 + baseOv(2) + 1 = 35
   723	                    ++cursor;
   724	                }
   725	            }
   726	
   727	            // Bucket fully drained: free it and advance to the next day.
   728	            if (total != 0) delete foilBuyers[dd];
   729	            unchecked {
   730	                ++dd;
   731	            }
   732	            cursor = 0;
   733	        }
   734	
   735	        // Caught up: dd is past the high-water mark or at a not-yet-sealed bucket.
   736	        foilDrainDay = dd;
   737	        foilCursor = 0;
   738	        return true;
   739	    }
   740	
   741	    /// @dev Resolve one queued buyer (the packed level<<160|buyer entry): re-derive
   742	    ///      the four boosted four-quadrant lines via the shared _deriveFoilLines, then
   743	    ///      file all sixteen traits into the cycle level's trait buckets. No stamp —
   744	    ///      the claim re-derives the SAME lines from rngWordByDay[resolveDay] + the
   745	    ///      frozen multBps, so the stored record stays just (multBps, resolveDay).
   746	    function _resolveFoilBuyer(
   747	        uint256 packedLvlBuyer,
   748	        uint256 entropy,
   749	        uint32[256] memory counts,
   750	        uint8[256] memory touchedTraits
   751	    ) private {
   752	        address buyer = address(uint160(packedLvlBuyer));
   753	        uint24 lvl = uint24(packedLvlBuyer >> 160);
   754	        uint32[4] memory lines = _deriveFoilLines(
   755	            buyer,
   756	            lvl,
   757	            entropy,
   758	            _foilMultFor(buyer, lvl)
   759	        );
   760	
   761	        uint16 touchedLen;
   762	        for (uint256 i; i < 4; ++i) {
   763	            uint32 line = lines[i];
   764	            uint8 tA = uint8(line);
   765	            uint8 tB = uint8(line >> 8);
   766	            uint8 tC = uint8(line >> 16);
   767	            uint8 tD = uint8(line >> 24);
   768	            if (counts[tA]++ == 0) touchedTraits[touchedLen++] = tA;
   769	            if (counts[tB]++ == 0) touchedTraits[touchedLen++] = tB;
   770	            if (counts[tC]++ == 0) touchedTraits[touchedLen++] = tC;
   771	            if (counts[tD]++ == 0) touchedTraits[touchedLen++] = tD;
   772	        }
   773	
   774	        // Batch-write the sixteen entries into traitBurnTicket[lvl][traitId], one
   775	        // length update per distinct trait. Mirrors the mint module's batch writer;
   776	        // re-zeroes the shared scratch so the next buyer starts clean.
   777	        uint256 levelSlot;
   778	        assembly ("memory-safe") {
   779	            mstore(0x00, lvl)
   780	            mstore(0x20, traitBurnTicket.slot)
   781	            levelSlot := keccak256(0x00, 0x40)
   782	        }
   783	        for (uint16 u; u < touchedLen; ) {
   784	            uint8 traitId = touchedTraits[u];
   785	            uint32 occurrences = counts[traitId];
   786	            counts[traitId] = 0;
   787	            assembly ("memory-safe") {
   788	                let elem := add(levelSlot, traitId)
   789	                let len := sload(elem)
   790	                sstore(elem, add(len, occurrences))
   791	                mstore(0x00, elem)
   792	                let dst := add(keccak256(0x00, 0x20), len)
   793	                for {
   794	                    let k := 0
   795	                } lt(k, occurrences) {
   796	                    k := add(k, 1)
   797	                } {
   798	                    sstore(dst, buyer)
   799	                    dst := add(dst, 1)
   800	                }
   801	            }
   802	            unchecked {
   803	                ++u;
   804	            }
   805	        }
   806	
   807	        uint256 baseKey = (uint256(lvl) << 224) |
   808	            (uint256(uint160(buyer)) << 32);
   809	        emit TraitsGenerated(buyer, baseKey, FOIL_PACK_ENTRIES);
   810	    }
   811	}

