   393	            // dispatches through the facade stub back into this module in the Game's
   394	            // storage context. try/catch isolates each claim — a revert (non-claimable
   395	            // OR an unpayable payout spin, e.g. an ETH tier the frozen pool can't cover)
   396	            // rolls back ONLY that tuple's effects and the sweep continues.
   397	            try
   398	                this.claimFoilMatch(
   399	                    players[i],
   400	                    drawDays[i],
   401	                    ticketIndexes[i],
   402	                    drawKinds[i]
   403	                )
   404	            {
   405	                unchecked {
   406	                    ++settled;
   407	                }
   408	            } catch {
   409	                // Non-claimable or payout-reverting tuple: skip.
   410	            }
   411	            unchecked {
   412	                ++i;
   413	            }
   414	        }
   415	
   416	        // Keeper bounty: a small FLIP credit per claim actually settled, paid to the
   417	        // caller during a live game (the flip credit is worthless post-gameover).
   418	        // Skipped and non-winning tuples settle nothing and earn nothing, so a padded
   419	        // batch cannot farm the bounty. The ETH-value tracks the per-claim settle gas
   420	        // at the reference price (FLIP per ETH = PRICE_COIN_UNIT / mintPrice), so the
   421	        // credit holds its gas-reimbursement value across the price curve.
   422	        if (!gameOver && settled != 0) {
   423	            coinflip.creditFlip(
   424	                msg.sender,
   425	                (settled * FOIL_CLAIM_BOUNTY_ETH_TARGET * PRICE_COIN_UNIT) /
   426	                    PriceLookupLib.priceForLevel(
   427	                        jackpotPhaseFlag ? level : level + 1
   428	                    )
   429	            );
   430	        }

