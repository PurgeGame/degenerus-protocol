{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://degenerus.io/schemas/function-audit-report.json",
  "title": "Function-Level Audit Report",
  "description": "JSON Schema for function-level audit reports used across Degenerus protocol Phases 50-57. Defines the structure for per-contract audit reports containing individual function audits, ETH mutation paths, and findings summaries.",
  "type": "object",
  "required": ["contract", "file", "functions"],
  "additionalProperties": false,
  "properties": {
    "contract": {
      "type": "string",
      "description": "Contract name (e.g., 'DegenerusGameAdvanceModule')"
    },
    "file": {
      "type": "string",
      "description": "File path relative to project root (e.g., 'contracts/modules/DegenerusGameAdvanceModule.sol')"
    },
    "lines": {
      "type": "integer",
      "minimum": 1,
      "description": "Total line count of the source file"
    },
    "solidity": {
      "type": "string",
      "description": "Solidity compiler version (e.g., '0.8.34')"
    },
    "inherits": {
      "type": "string",
      "description": "Parent contract (e.g., 'DegenerusGameStorage')"
    },
    "calledVia": {
      "type": "string",
      "description": "How this contract is invoked (e.g., 'delegatecall from DegenerusGame')"
    },
    "auditDate": {
      "type": "string",
      "format": "date",
      "description": "Date the audit was performed (ISO 8601 date)"
    },
    "summary": {
      "type": "string",
      "description": "Brief description of what the contract does and its role in the protocol"
    },
    "functions": {
      "type": "array",
      "description": "Array of per-function audit entries",
      "items": {
        "$ref": "#/$defs/FunctionAudit"
      }
    },
    "ethMutationPaths": {
      "type": "array",
      "description": "ETH flow paths showing how ETH enters, moves between pools, or exits through this contract",
      "items": {
        "$ref": "#/$defs/EthMutationPath"
      }
    },
    "findingsSummary": {
      "$ref": "#/$defs/FindingsSummary",
      "description": "Aggregated severity counts for the entire audit report"
    }
  },
  "$defs": {
    "Parameter": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name"
        },
        "type": {
          "type": "string",
          "description": "Solidity type (e.g., 'uint256', 'address', 'bytes32')"
        },
        "description": {
          "type": "string",
          "description": "What the parameter represents"
        }
      }
    },
    "ReturnValue": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Solidity return type"
        },
        "name": {
          "type": "string",
          "description": "Named return variable (if applicable)"
        },
        "description": {
          "type": "string",
          "description": "What the return value represents"
        }
      }
    },
    "CallerEntry": {
      "type": "object",
      "required": ["function"],
      "additionalProperties": false,
      "properties": {
        "function": {
          "type": "string",
          "description": "Name of the calling function"
        },
        "contract": {
          "type": "string",
          "description": "Contract containing the caller (if different from audited contract)"
        },
        "callType": {
          "type": "string",
          "enum": ["internal", "external", "delegatecall", "view"],
          "description": "How the call is made"
        }
      }
    },
    "CalleeEntry": {
      "type": "object",
      "required": ["function"],
      "additionalProperties": false,
      "properties": {
        "function": {
          "type": "string",
          "description": "Name of the called function"
        },
        "contract": {
          "type": "string",
          "description": "Contract containing the callee (if different from audited contract)"
        },
        "callType": {
          "type": "string",
          "enum": ["internal", "external", "delegatecall", "view"],
          "description": "How the call is made"
        }
      }
    },
    "EthFlowPath": {
      "type": "object",
      "required": ["source", "destination"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Where ETH originates (e.g., 'nextPrizePool', 'msg.value')"
        },
        "destination": {
          "type": "string",
          "description": "Where ETH ends up (e.g., 'claimableWinnings', 'stETH')"
        },
        "description": {
          "type": "string",
          "description": "Description of the ETH movement"
        }
      }
    },
    "EthFlow": {
      "type": "object",
      "required": ["hasEthFlow"],
      "additionalProperties": false,
      "properties": {
        "hasEthFlow": {
          "type": "boolean",
          "description": "Whether this function directly or indirectly moves ETH"
        },
        "details": {
          "type": "string",
          "description": "Description of ETH flow behavior"
        },
        "paths": {
          "type": "array",
          "description": "Individual ETH movement paths within this function",
          "items": {
            "$ref": "#/$defs/EthFlowPath"
          }
        }
      }
    },
    "NatSpecAccuracy": {
      "type": "object",
      "required": ["accurate"],
      "additionalProperties": false,
      "properties": {
        "accurate": {
          "type": "boolean",
          "description": "Whether the NatSpec documentation matches actual behavior"
        },
        "notes": {
          "type": "string",
          "description": "Details about NatSpec accuracy or discrepancies"
        }
      }
    },
    "GasFlag": {
      "type": "object",
      "required": ["type", "description"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["impossible-condition", "redundant-read", "unnecessary-computation", "other"],
          "description": "Category of gas concern"
        },
        "description": {
          "type": "string",
          "description": "Description of the gas concern"
        },
        "severity": {
          "type": "string",
          "enum": ["high", "medium", "low", "info"],
          "description": "Impact severity of the gas concern"
        }
      }
    },
    "FunctionAudit": {
      "type": "object",
      "required": ["name", "signature", "visibility", "mutability", "stateReads", "stateWrites", "verdict"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Function name (e.g., 'advanceGame')"
        },
        "signature": {
          "type": "string",
          "description": "Full Solidity function signature (e.g., 'function advanceGame() external')"
        },
        "visibility": {
          "type": "string",
          "enum": ["external", "public", "internal", "private"],
          "description": "Solidity visibility specifier"
        },
        "mutability": {
          "type": "string",
          "enum": ["state-changing", "view", "pure"],
          "description": "Solidity mutability classification"
        },
        "parameters": {
          "type": "array",
          "description": "Function parameters with names, types, and descriptions",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "returns": {
          "type": "array",
          "description": "Return values with types and descriptions",
          "items": {
            "$ref": "#/$defs/ReturnValue"
          }
        },
        "stateReads": {
          "type": "array",
          "description": "Every storage variable or context value read by this function",
          "items": {
            "type": "string"
          }
        },
        "stateWrites": {
          "type": "array",
          "description": "Every storage variable written by this function",
          "items": {
            "type": "string"
          }
        },
        "callers": {
          "type": "array",
          "description": "Functions that call this one, with call type context",
          "items": {
            "$ref": "#/$defs/CallerEntry"
          }
        },
        "callees": {
          "type": "array",
          "description": "Functions that this one calls, with call type context",
          "items": {
            "$ref": "#/$defs/CalleeEntry"
          }
        },
        "ethFlow": {
          "oneOf": [
            { "$ref": "#/$defs/EthFlow" },
            { "type": "null" }
          ],
          "description": "ETH flow information, or null if no ETH movement"
        },
        "invariants": {
          "type": "array",
          "description": "Conditions that must remain true before and after execution",
          "items": {
            "type": "string"
          }
        },
        "natspecAccuracy": {
          "$ref": "#/$defs/NatSpecAccuracy",
          "description": "Assessment of whether NatSpec documentation matches actual behavior"
        },
        "gasFlags": {
          "type": "array",
          "description": "Gas efficiency concerns (impossible conditions, redundant reads, etc.)",
          "items": {
            "$ref": "#/$defs/GasFlag"
          }
        },
        "verdict": {
          "type": "string",
          "enum": ["CORRECT", "CONCERN", "BUG"],
          "description": "Overall assessment of the function's correctness"
        },
        "verdictNotes": {
          "type": "string",
          "description": "Explanation for CONCERN or BUG verdicts, or additional notes for CORRECT verdicts"
        }
      }
    },
    "EthMutationPath": {
      "type": "object",
      "required": ["source", "destination", "trigger", "function"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Where ETH originates (pool, balance, msg.value)"
        },
        "destination": {
          "type": "string",
          "description": "Where ETH ends up (pool, address, external contract)"
        },
        "trigger": {
          "type": "string",
          "description": "What causes this ETH movement (e.g., 'Last purchase day, before pool consolidation')"
        },
        "function": {
          "type": "string",
          "description": "Function that executes the ETH movement"
        },
        "notes": {
          "type": "string",
          "description": "Additional context about the ETH path"
        }
      }
    },
    "FindingsSummary": {
      "type": "object",
      "required": ["correct", "total"],
      "additionalProperties": false,
      "properties": {
        "bug": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of BUG findings"
        },
        "concern": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of CONCERN findings"
        },
        "gas": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of GAS findings (efficiency concerns)"
        },
        "correct": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of functions verified CORRECT"
        },
        "total": {
          "type": "integer",
          "minimum": 1,
          "description": "Total number of functions audited"
        }
      }
    }
  }
}
