# Deployer private key (without 0x prefix or with — both work)
DEPLOYER_PRIVATE_KEY=

# Network RPC URLs
RPC_URL=
HARDHAT_FORK_URL=

# Block explorer verification
ETHERSCAN_API_KEY=

# External contract addresses (Ethereum Mainnet defaults)
STETH_TOKEN=0xae7ab96520DE3A18E5e111B5EaAb095312D7fE84
LINK_TOKEN=0x514910771AF9Ca656af840dff83E8264EcF986CA
VRF_COORDINATOR=0x271682DEB8C4E0901D1a1550aD2e64D568E69909
VRF_KEY_HASH=0x8af398995b04c28e9951adb9721ef74c74f93e6a478f39e7e0777be13527e7ef
WXRP=0x0000000000000000000000000000000000000000

# Optional: pre-seed affiliate codes at deployment.
# Format: JSON array of { owner, code, rakebackPct } objects.
# - owner: address
# - code: bytes32 hex (0x...) OR short ASCII label (<=31 chars)
# - rakebackPct: integer 0-25 (optional, defaults to 0)
# Example:
# AFFILIATE_BOOTSTRAP_JSON=[{"owner":"0xabc...","code":"KOL1","rakebackPct":10}]
AFFILIATE_BOOTSTRAP_JSON=

# Optional: pre-seed player -> referral code mappings at deployment.
# Format: JSON array of { player, code } objects.
# - player: address
# - code: bytes32 hex (0x...) OR short ASCII label (<=31 chars)
# Example:
# AFFILIATE_PREFERRALS_JSON=[{"player":"0xdef...","code":"KOL1"}]
AFFILIATE_PREFERRALS_JSON=
